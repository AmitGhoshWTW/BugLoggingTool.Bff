# pwa-blt/.env.example
# Copy to .env.local and fill in your values.
# All VITE_ prefixed vars are embedded into the React build at compile time.

# Azure AD — required for SSO
# VITE_AAD_CLIENT_ID=e0c49757-c685-4da6-9584-a6945b83b32b
# VITE_AAD_TENANT_ID=b29e2636-6da7-42ad-be61-cf8af077f50f

# If authConfig.js uses VITE_AAD_CLIENT_ID / VITE_AAD_TENANT_ID
VITE_AZURE_AD_CLIENT_ID=e0c49757-c685-4da6-9584-a6945b83b32b
VITE_AZURE_AD_TENANT_ID=b29e2636-6da7-42ad-be61-cf8af077f50f

# JIRA Service URL — points to BFF /api/jira in production
# In development: http://localhost:5000 (BFF running locally)
# In production:  https://blt.yourcompany.com (BFF on Azure)
VITE_JIRA_SERVICE_URL=http://localhost:5011


# VITE_AZURE_AD_CLIENT_ID=e0c49757-c685-4da6-9584-a6945b83b32b
# VITE_AZURE_AD_TENANT_ID=b29e2636-6da7-42ad-be61-cf8af077f50f
# VITE_AZURE_AD_REDIRECT_URI=http://localhost:3000
