<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<packageSources>
		<!--
      Adds nuget.org so public packages (Serilog, Dapper, etc.) can be restored
      alongside your enterprise feeds.
      Your existing enterprise feeds still take priority for internal packages.
    -->
		<add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
	</packageSources>
</configuration>